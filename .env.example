# Copy this file to .env and fill in your values. Never commit .env.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# Quality model — used only for the main resume tailoring rewrite
OPENAI_MODEL=gpt-4o

# Fast/cheap model — used for parsing, chat edits, cover letter, email (~15x cheaper)
OPENAI_MODEL_FAST=gpt-4o-mini

# ── Google OAuth (optional — leave blank to disable Google Sign-In) ────────────
# Get these from: https://console.cloud.google.com
#   → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
#   → Authorised JavaScript origins:  http://localhost:3000
#   → Authorised redirect URIs:       http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=